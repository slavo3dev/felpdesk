{
    "extends": "expo/tsconfig.base",
    "compilerOptions": {
        "strict": true,
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "src/*"
            ],
            "@/components": [
                "src/components/*"
            ],
            "@/lib": [
                "src/lib/*"
            ],
            "@/types": [
                "src/types/*"
            ],
            "@/assets": [
                "assets/*"
            ]
        }
    }
}